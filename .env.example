# Plaid — get these from dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox   # sandbox | production

# OpenRouter — openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Gemini — aistudio.google.com (free, 1500 grounded search requests/day)
# Required for card reward rate fetching (/settings → Card Reward Rates → Fetch Rates)
GEMINI_API_KEY=

# Auth
SESSION_SECRET=     # generate: openssl rand -base64 32

# Encryption key for Plaid access tokens at rest (optional — derived from SESSION_SECRET if not set)
# If set, must be exactly 32 bytes hex-encoded: openssl rand -hex 32
ENCRYPTION_KEY=
WEBAUTHN_RPID=localhost
WEBAUTHN_RPORIGIN=http://localhost:8080

# App
DB_PATH=./holo.db
PORT=8080

# Investments (Phase 4)
INVEST_BUFFER_CAD=500
