# Plaid — get these from dashboard.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox   # sandbox | production

# OpenRouter — openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Auth
SESSION_SECRET=     # generate: openssl rand -base64 32

# Encryption key for Plaid access tokens at rest (optional — derived from SESSION_SECRET if not set)
# If set, must be exactly 32 bytes hex-encoded: openssl rand -hex 32
ENCRYPTION_KEY=

# WebAuthn — RPID is the bare domain the passkey is registered against (no protocol, no port).
# RPORIGINS is a comma-separated list of full origins allowed to authenticate; {port} is substituted with PORT.
# Passkeys are tied to RPID at registration — changing it requires re-registering.
WEBAUTHN_RPID=localhost
WEBAUTHN_RPORIGINS=http://localhost:{port}

# App
DB_PATH=./holo.db
PORT=8080

# Investments — monthly buffer to keep in cash before recommending contributions
INVEST_BUFFER_CAD=500
