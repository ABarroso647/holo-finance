package components

import (
	"fmt"
	"math"
	"time"
	db "holo/internal/db/generated"
)

type CardSummary struct {
	Account    db.ListAccountsWithInstitutionRow
	Liability  *db.CreditCardLiability
	SpendTotal float64
	SpendLabel string
	TopCats    []db.GetTopCategoriesForAccountRow
	Rates      []db.ListCardRewardRatesForAccountRow
}

templ CardsPage(cards []CardSummary) {
	@Layout("Cards") {
		<div class="page-header">
			<h1>Credit Cards</h1>
			<div style="display:flex;gap:0.5rem;align-items:center">
				<button
					class="btn btn-ghost"
					hx-post="/api/plaid/sync-liabilities"
					hx-target="#liab-result"
					hx-swap="innerHTML"
					hx-indicator="#liab-spinner"
					hx-disabled-elt="this"
				>
					<span id="liab-spinner" class="htmx-indicator">⟳</span>
					Sync Payment Data
				</button>
				<span id="liab-result" style="font-size:0.8rem"></span>
			</div>
		</div>
		if len(cards) == 0 {
			<div class="card">
				<p style="color:var(--muted)">No credit card accounts found. Connect a bank and sync to get started.</p>
			</div>
		} else {
			<div style="display:flex;flex-direction:column;gap:1.25rem">
				for _, card := range cards {
					@CardCard(card)
				}
			</div>
		}
	}
}

templ CardCard(card CardSummary) {
	<div class="card">
		<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:1rem">
			<div>
				<div style="font-size:1rem;font-weight:600">
					if card.Account.DisplayName != nil && *card.Account.DisplayName != "" {
						{ *card.Account.DisplayName }
					} else {
						{ card.Account.Name }
					}
				</div>
				<div style="font-size:0.75rem;color:var(--muted)">{ card.Account.InstitutionName }</div>
			</div>
			<span class="badge badge-credit" style="font-size:0.7rem">credit</span>
		</div>
		<div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem">
			<div>
				<div style="font-size:0.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.25rem">Balance</div>
				if card.Account.CurrentBalance != nil {
					<div style="font-size:1.4rem;font-weight:700;color:var(--text)">{ fmt.Sprintf("$%.2f", *card.Account.CurrentBalance) }</div>
				} else {
					<div style="color:var(--muted)">—</div>
				}
			</div>
			<div>
				<div style="font-size:0.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.25rem">Available Credit</div>
				if card.Account.AvailableBalance != nil {
					<div style="font-size:1.4rem;font-weight:700;color:var(--green)">{ fmt.Sprintf("$%.2f", *card.Account.AvailableBalance) }</div>
				} else {
					<div style="color:var(--muted)">—</div>
				}
			</div>
		</div>
		if card.Account.CurrentBalance != nil && card.Account.AvailableBalance != nil {
			{{ limit := *card.Account.CurrentBalance + *card.Account.AvailableBalance }}
			{{ util := utilizationPct(*card.Account.CurrentBalance, limit) }}
			<div style="margin-bottom:1rem">
				<div style="display:flex;justify-content:space-between;font-size:0.75rem;color:var(--muted);margin-bottom:0.3rem">
					<span>Utilization { fmt.Sprintf("%.0f%%", util) }</span>
					<span>{ fmt.Sprintf("$%.0f limit", limit) }</span>
				</div>
				<div style="background:var(--border);border-radius:4px;height:6px;overflow:hidden">
					<div style={ fmt.Sprintf("width:%.0f%%;height:100%%;background:%s;border-radius:4px;transition:width 0.3s", math.Min(util, 100), utilColor(util)) }></div>
				</div>
			</div>
		}
		<div style="display:grid;grid-template-columns:1fr 1fr;gap:1.5rem">
			<div>
				@cardPaymentSection(card.Liability)
			</div>
			<div>
				@cardSpendSection(card.SpendTotal, card.SpendLabel, card.TopCats)
			</div>
		</div>
		<div style="margin-top:1rem;border-top:1px solid var(--border);padding-top:1rem">
			@CardRatesTable(card.Account.ID, card.Rates)
		</div>
	</div>
}

templ cardPaymentSection(liab *db.CreditCardLiability) {
	<div style="font-size:0.7rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.5rem">Payment</div>
	if liab == nil {
		<p style="font-size:0.8rem;color:var(--muted)">Payment data unavailable. Click "Sync Payment Data" after Plaid Liabilities is enabled.</p>
	} else {
		<div style="display:flex;flex-direction:column;gap:0.4rem;font-size:0.82rem">
			if liab.IsOverdue == 1 {
				<div style="color:var(--red);font-weight:600;font-size:0.8rem">⚠ Payment overdue</div>
			}
			if liab.NextPaymentDueDate != nil {
				{{ days := daysUntil(*liab.NextPaymentDueDate) }}
				<div style="display:flex;justify-content:space-between">
					<span style="color:var(--muted)">Due</span>
					<span style={ fmt.Sprintf("color:%s;font-weight:500", dueDateColor(days)) }>
						{ formatCardDate(*liab.NextPaymentDueDate) }
						<span style="font-size:0.72rem;color:var(--muted)">({ daysLabel(days) })</span>
					</span>
				</div>
			}
			if liab.MinimumPaymentAmount != nil {
				<div style="display:flex;justify-content:space-between">
					<span style="color:var(--muted)">Minimum</span>
					<span>{ fmt.Sprintf("$%.2f", *liab.MinimumPaymentAmount) }</span>
				</div>
			}
			if liab.LastStatementBalance != nil {
				<div style="display:flex;justify-content:space-between">
					<span style="color:var(--muted)">Statement balance</span>
					<span>{ fmt.Sprintf("$%.2f", *liab.LastStatementBalance) }</span>
				</div>
			}
			if liab.LastPaymentAmount != nil && liab.LastPaymentDate != nil {
				<div style="display:flex;justify-content:space-between">
					<span style="color:var(--muted)">Last payment</span>
					<span style="color:var(--green)">{ fmt.Sprintf("$%.2f", *liab.LastPaymentAmount) } <span style="color:var(--muted);font-size:0.72rem">{ formatCardDate(*liab.LastPaymentDate) }</span></span>
				</div>
			}
		</div>
	}
}

templ cardSpendSection(total float64, label string, topCats []db.GetTopCategoriesForAccountRow) {
	<div style="font-size:0.7rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.5rem">Spending</div>
	<div style="font-size:1.1rem;font-weight:600;margin-bottom:0.5rem">
		{ fmt.Sprintf("$%.2f", total) }
		<span style="font-size:0.75rem;font-weight:400;color:var(--muted)">{ label }</span>
	</div>
	if len(topCats) > 0 {
		{{ maxTotal := topCats[0].Total }}
		<div style="display:flex;flex-direction:column;gap:0.35rem">
			for _, cat := range topCats {
				<div style="display:flex;align-items:center;gap:0.4rem;font-size:0.75rem">
					<span style={ fmt.Sprintf("width:6px;height:6px;border-radius:50%%;background:%s;flex-shrink:0", cat.CategoryColor) }></span>
					<span style="flex:1;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">{ cat.CategoryName }</span>
					<div style="width:50px;background:var(--border);border-radius:2px;height:3px;overflow:hidden">
						<div style={ fmt.Sprintf("width:%.0f%%;height:100%%;background:%s", (cat.Total/maxTotal)*100, cat.CategoryColor) }></div>
					</div>
					<span style="color:var(--muted);font-variant-numeric:tabular-nums;width:48px;text-align:right">{ fmt.Sprintf("$%.0f", cat.Total) }</span>
				</div>
			}
		</div>
	} else {
		<p style="font-size:0.8rem;color:var(--muted)">No spend in this period.</p>
	}
}

templ CardRatesTable(accountID string, rates []db.ListCardRewardRatesForAccountRow) {
	<div id={ fmt.Sprintf("card-rates-%s", accountID) }>
		<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem">
			<div style="font-size:0.7rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.05em">Reward Rates</div>
			<div style="display:flex;gap:0.5rem;align-items:center">
				<form
					hx-post={ fmt.Sprintf("/api/cards/%s/fetch-rates", accountID) }
					hx-target={ fmt.Sprintf("#card-rates-%s", accountID) }
					hx-swap="outerHTML"
					hx-indicator={ fmt.Sprintf("#rates-spinner-%s", accountID) }
					style="display:inline"
				>
					<span id={ fmt.Sprintf("rates-spinner-%s", accountID) } class="spin-indicator"></span>
					<button type="submit" class="btn btn-ghost" style="font-size:0.72rem;padding:0.2rem 0.5rem" hx-disabled-elt="this">Fetch Rates</button>
				</form>
			</div>
		</div>
		if len(rates) == 0 {
			<p style="font-size:0.8rem;color:var(--muted)">No rates configured. Click "Fetch Rates" to look up via Jina + DeepSeek, or add manually in Settings.</p>
		} else {
			<div style="display:flex;flex-direction:column;gap:0.25rem">
				for _, rate := range rates {
					<div style="display:flex;justify-content:space-between;align-items:center;font-size:0.78rem">
						<span style="color:var(--muted);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
							if rate.CategoryName != "" {
								{ rate.CategoryName }
							} else if rate.RawCategory != nil {
								<span style="color:var(--yellow)">{ *rate.RawCategory }</span>
							} else {
								<span style="color:var(--muted);font-style:italic">catch-all</span>
							}
						</span>
						<span style="font-weight:600;color:var(--text);margin-left:0.5rem">
							{ fmt.Sprintf("%.1f%%", rate.RewardRate) }
							if rate.CapAmount != nil {
								<span style="font-size:0.68rem;color:var(--muted);font-weight:400"> / ${ fmt.Sprintf("%.0f", *rate.CapAmount) }{ capPeriodLabel(rate.CapPeriod) } cap</span>
							}
						</span>
						<button
							type="button"
							hx-delete={ fmt.Sprintf("/api/cards/%s/rates/%s", accountID, rate.ID) }
							hx-target={ fmt.Sprintf("#card-rates-%s", accountID) }
							hx-swap="outerHTML"
							hx-confirm="Remove this rate?"
							style="background:none;border:none;color:var(--muted);cursor:pointer;padding:0 0 0 0.4rem;font-size:0.8rem;line-height:1"
							title="Remove rate"
						>×</button>
					</div>
				}
			</div>
		}
	</div>
}

func capPeriodLabel(p *string) string {
	if p == nil || *p == "" {
		return ""
	}
	if *p == "monthly" {
		return "/mo"
	}
	return "/yr"
}

func utilizationPct(balance, limit float64) float64 {
	if limit <= 0 {
		return 0
	}
	return (balance / limit) * 100
}

func utilColor(pct float64) string {
	if pct >= 70 {
		return "var(--red)"
	}
	if pct >= 30 {
		return "var(--yellow)"
	}
	return "var(--green)"
}

func daysUntil(dateStr string) int {
	t, err := time.Parse("2006-01-02", dateStr)
	if err != nil {
		return 999
	}
	now := time.Now().UTC()
	today := time.Date(now.Year(), now.Month(), now.Day(), 0, 0, 0, 0, time.UTC)
	due := time.Date(t.Year(), t.Month(), t.Day(), 0, 0, 0, 0, time.UTC)
	return int(due.Sub(today).Hours() / 24)
}

func daysLabel(days int) string {
	if days < 0 {
		return fmt.Sprintf("%d days overdue", -days)
	}
	if days == 0 {
		return "due today"
	}
	if days == 1 {
		return "tomorrow"
	}
	return fmt.Sprintf("in %d days", days)
}

func dueDateColor(days int) string {
	if days < 0 {
		return "var(--red)"
	}
	if days <= 7 {
		return "var(--red)"
	}
	if days <= 14 {
		return "var(--yellow)"
	}
	return "var(--text)"
}

func formatCardDate(dateStr string) string {
	t, err := time.Parse("2006-01-02", dateStr)
	if err != nil {
		return dateStr
	}
	return t.Format("Jan 2")
}
