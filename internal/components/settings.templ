package components

import (
	"fmt"
	db "github.com/abarroso647/holo/internal/db/generated"
)

type CardRatesData struct {
	Account db.ListAccountsWithInstitutionRow
	Rates   []db.ListCardRewardRatesForAccountRow
}

templ SettingsPage(accounts []db.ListAccountsWithInstitutionRow, categories []db.Category, rules []db.ListRulesRow, model string, cardRates []CardRatesData, tags []db.Tag, spendByTag []db.GetSpendByTagRow) {
	@Layout("Settings") {
		<div class="page-header">
			<h1>Settings</h1>
		</div>
		<div style="display:flex;flex-direction:column;gap:1.5rem">
			@settingsAccountNames(accounts)
			@settingsCategories(categories)
			@settingsRules(rules)
			@TagsSettingsSection(tags, spendByTag)
			@settingsCardRates(cardRates, categories)
			@settingsAI(model)
			@settingsExport()
		</div>
	}
}

templ settingsAccountNames(accounts []db.ListAccountsWithInstitutionRow) {
	<div class="card">
		<h2 style="margin-bottom:0.25rem">Account Display Names</h2>
		<p style="color:var(--muted);font-size:0.8rem;margin-bottom:1rem">Set a friendly name shown throughout the app instead of the raw bank account name.</p>
		if len(accounts) == 0 {
			<p style="color:var(--muted);font-size:0.85rem">No accounts connected yet.</p>
		} else {
			<table>
				<thead>
					<tr>
						<th>Institution</th>
						<th>Account</th>
						<th>Display Name</th>
					</tr>
				</thead>
				<tbody>
					for _, a := range accounts {
						@AccountDisplayNameRow(a)
					}
				</tbody>
			</table>
		}
	</div>
}

templ AccountDisplayNameRow(a db.ListAccountsWithInstitutionRow) {
	<tr id={ fmt.Sprintf("acct-dn-%s", a.ID) }>
		<td style="color:var(--muted);font-size:0.8rem">{ a.InstitutionName }</td>
		<td style="font-size:0.85rem">{ a.Name }</td>
		<td>
			<form
				style="display:flex;gap:0.4rem;align-items:center"
				hx-post={ fmt.Sprintf("/api/accounts/%s/display-name", a.ID) }
				hx-target={ fmt.Sprintf("#acct-dn-%s", a.ID) }
				hx-swap="outerHTML"
			>
				<input
					type="text"
					name="display_name"
					class="filter-input"
					style="width:200px"
					if a.DisplayName != nil {
						value={ *a.DisplayName }
					}
					placeholder="e.g. Main Chequing"
				/>
				<button type="submit" class="btn btn-ghost" style="font-size:0.8rem;padding:0.25rem 0.6rem">Save</button>
			</form>
		</td>
	</tr>
}

templ settingsCategories(categories []db.Category) {
	<div class="card">
		<h2 style="margin-bottom:0.25rem">Categories</h2>
		<p style="color:var(--muted);font-size:0.8rem;margin-bottom:1rem">Rename or recolor your spending categories.</p>
		<table>
			<thead>
				<tr>
					<th style="width:2rem"></th>
					<th>Name</th>
					<th style="width:6rem">Color</th>
					<th style="width:5rem"></th>
				</tr>
			</thead>
			<tbody>
				for _, cat := range categories {
					@CategorySettingsRow(cat)
				}
			</tbody>
		</table>
	</div>
}

templ CategorySettingsRow(cat db.Category) {
	<tr id={ fmt.Sprintf("cat-row-%s", cat.ID) }>
		<td>
			<span style={ fmt.Sprintf("width:12px;height:12px;border-radius:50%%;background:%s;display:inline-block", catColor(cat)) }></span>
		</td>
		<td>
			<form
				style="display:flex;gap:0.4rem;align-items:center"
				hx-post={ fmt.Sprintf("/api/categories/%s", cat.ID) }
				hx-target={ fmt.Sprintf("#cat-row-%s", cat.ID) }
				hx-swap="outerHTML"
			>
				<input
					type="text"
					name="name"
					class="filter-input"
					style="width:200px"
					value={ cat.Name }
				/>
				<input
					type="color"
					name="color"
					style="width:2.5rem;height:2rem;border:1px solid var(--border);border-radius:4px;cursor:pointer;background:var(--surface);padding:2px"
					if cat.Color != nil {
						value={ *cat.Color }
					} else {
						value="#64748b"
					}
				/>
				<button type="submit" class="btn btn-ghost" style="font-size:0.8rem;padding:0.25rem 0.6rem">Save</button>
			</form>
		</td>
		<td></td>
		<td></td>
	</tr>
}

templ settingsRules(rules []db.ListRulesRow) {
	<div class="card">
		<h2 style="margin-bottom:0.25rem">Categorization Rules</h2>
		<p style="color:var(--muted);font-size:0.8rem;margin-bottom:1rem">Rules run before the LLM and take priority. Created via "+ rule" on the transactions page.</p>
		if len(rules) == 0 {
			<p style="color:var(--muted);font-size:0.85rem">No rules yet. Open a transaction, manually set a category, then click "+ rule".</p>
		} else {
			<table>
				<thead>
					<tr>
						<th>Match</th>
						<th>Category</th>
						<th style="width:5rem"></th>
					</tr>
				</thead>
				<tbody>
					for _, rule := range rules {
						<tr id={ fmt.Sprintf("rule-row-%s", rule.ID) }>
							<td style="font-size:0.85rem">
								<span style="color:var(--muted)">{ rule.MatchField }</span>
								<span style="color:var(--muted);margin:0 0.25rem">contains</span>
								<span style="color:var(--text)">"{ rule.MatchValue }"</span>
							</td>
							<td style="font-size:0.85rem;color:var(--muted)">{ rule.CategoryName }</td>
							<td>
								<button
									type="button"
									class="btn btn-ghost"
									style="font-size:0.75rem;padding:0.2rem 0.5rem;color:var(--red);border-color:var(--red)"
									hx-delete={ fmt.Sprintf("/api/rules/%s", rule.ID) }
									hx-target={ fmt.Sprintf("#rule-row-%s", rule.ID) }
									hx-swap="outerHTML"
									hx-confirm="Delete this rule?"
								>Delete</button>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}
	</div>
}

templ TagsSettingsSection(tags []db.Tag, spendByTag []db.GetSpendByTagRow) {
	<div id="tags-settings-section" class="card">
		<h2 style="margin-bottom:0.25rem">Tags</h2>
		<p style="color:var(--muted);font-size:0.8rem;margin-bottom:1rem">Create tags to label transactions across categories. Filter by tag on the Transactions page.</p>
		<form
			style="display:flex;gap:0.4rem;align-items:center;margin-bottom:1rem"
			hx-post="/api/tags"
			hx-target="#tags-settings-section"
			hx-swap="outerHTML"
			hx-on--htmx-after-request="this.reset()"
		>
			<input
				type="text"
				name="name"
				class="filter-input"
				style="width:180px"
				placeholder="Tag name"
				required
			/>
			<input
				type="color"
				name="color"
				value="#6366f1"
				style="width:2.5rem;height:2rem;border:1px solid var(--border);border-radius:4px;cursor:pointer;background:var(--surface);padding:2px"
			/>
			<button type="submit" class="btn btn-ghost" style="font-size:0.8rem;padding:0.25rem 0.6rem">Create tag</button>
		</form>
		if len(tags) == 0 {
			<p style="color:var(--muted);font-size:0.85rem">No tags yet.</p>
		} else {
			{{ spendMap := tagSpendMap(spendByTag) }}
			<table>
				<thead>
					<tr>
						<th style="width:1.5rem"></th>
						<th>Name</th>
						<th style="text-align:right">All-time spend</th>
						<th style="text-align:right">Transactions</th>
						<th style="width:5rem"></th>
					</tr>
				</thead>
				<tbody>
					for _, tag := range tags {
						<tr>
							<td><span style={ fmt.Sprintf("width:10px;height:10px;border-radius:50%%;background:%s;display:inline-block", tag.Color) }></span></td>
							<td style="font-size:0.85rem">{ tag.Name }</td>
							<td style="text-align:right;font-variant-numeric:tabular-nums;font-size:0.85rem">
								if s, ok := spendMap[tag.ID]; ok {
									{ fmt.Sprintf("$%.2f", s.Total) }
								} else {
									<span style="color:var(--muted)">—</span>
								}
							</td>
							<td style="text-align:right;color:var(--muted);font-size:0.8rem">
								if s, ok := spendMap[tag.ID]; ok {
									{ fmt.Sprintf("%d", s.TxnCount) }
								} else {
									—
								}
							</td>
							<td style="text-align:right">
								<a
									href={ templ.SafeURL(fmt.Sprintf("/transactions?tag_id=%s", tag.ID)) }
									class="btn btn-ghost"
									style="font-size:0.72rem;padding:0.15rem 0.4rem;margin-right:0.25rem"
								>View</a>
								<button
									type="button"
									class="btn btn-ghost"
									style="font-size:0.72rem;padding:0.15rem 0.4rem;color:var(--red);border-color:var(--red)"
									hx-delete={ fmt.Sprintf("/api/tags/%s", tag.ID) }
									hx-target="#tags-settings-section"
									hx-swap="outerHTML"
									hx-confirm={ fmt.Sprintf("Delete tag \"%s\"? It will be removed from all transactions.", tag.Name) }
								>Delete</button>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}
	</div>
}

templ settingsCardRates(cards []CardRatesData, categories []db.Category) {
	<div class="card">
		<h2 style="margin-bottom:0.25rem">Card Reward Rates</h2>
		<p style="color:var(--muted);font-size:0.8rem;margin-bottom:1rem">
			Fetch earn rates per card. Uses Jina Search to find the card's page, then your OpenRouter model to parse the rates.
			No extra API key needed — uses your existing <code style="background:var(--border);padding:1px 4px;border-radius:3px">OPENROUTER_API_KEY</code>.
		</p>
		<div style="margin-bottom:0.75rem;display:flex;align-items:center;gap:0.5rem">
			<button
				type="button"
				class="btn btn-ghost"
				style="font-size:0.8rem"
				hx-post="/api/cards/rematch-rates"
				hx-target="#rematch-result"
				hx-swap="innerHTML"
				hx-indicator="#rematch-spinner"
				hx-disabled-elt="this"
			>
				<span id="rematch-spinner" class="htmx-indicator">⟳ </span>
				Re-match All Unmatched Rates
			</button>
			<span id="rematch-result" style="font-size:0.75rem"></span>
		</div>
		if len(cards) == 0 {
			<p style="color:var(--muted);font-size:0.85rem">No credit card accounts connected.</p>
		} else {
			<div style="display:flex;flex-direction:column;gap:1.25rem">
				for _, c := range cards {
					<div style="border:1px solid var(--border);border-radius:6px;padding:0.75rem">
						<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.5rem">
							<div>
								<div style="font-size:0.9rem;font-weight:600">
									if c.Account.DisplayName != nil && *c.Account.DisplayName != "" {
										{ *c.Account.DisplayName }
									} else {
										{ c.Account.Name }
									}
								</div>
								<div style="font-size:0.75rem;color:var(--muted)">{ c.Account.InstitutionName }</div>
							</div>
							<form
								hx-post={ fmt.Sprintf("/api/cards/%s/fetch-rates", c.Account.ID) }
								hx-target={ fmt.Sprintf("#settings-rates-%s", c.Account.ID) }
								hx-swap="outerHTML"
								hx-indicator={ fmt.Sprintf("#settings-rates-spinner-%s", c.Account.ID) }
								style="display:flex;gap:0.4rem;align-items:center"
							>
								<input
									type="text"
									name="card_name"
									class="filter-input"
									style="width:220px;font-size:0.8rem"
									placeholder="e.g. American Express Cobalt Canada"
									if c.Account.DisplayName != nil && *c.Account.DisplayName != "" {
										value={ *c.Account.DisplayName }
									} else {
										value={ c.Account.Name }
									}
								/>
								<input type="hidden" name="view" value="settings"/>
								<span id={ fmt.Sprintf("settings-rates-spinner-%s", c.Account.ID) } class="spin-indicator"></span>
								<button type="submit" class="btn btn-ghost" style="font-size:0.8rem;padding:0.25rem 0.6rem" hx-disabled-elt="this">Fetch Rates</button>
							</form>
						</div>
						@SettingsCardRatesContent(c.Account.ID, c.Rates, categories)
					</div>
				}
			</div>
		}
	</div>
}

// SettingsCardRatesContent renders the rates table + manual add form.
// HTMX swap target for fetch-rates, add-rate, and delete-rate from settings.
templ SettingsCardRatesContent(accountID string, rates []db.ListCardRewardRatesForAccountRow, categories []db.Category) {
	<div id={ fmt.Sprintf("settings-rates-%s", accountID) }>
		if len(rates) > 0 {
			<table style="font-size:0.8rem;width:100%;margin-bottom:0.75rem">
				<thead>
					<tr>
						<th style="text-align:left">Category</th>
						<th style="text-align:right">Rate</th>
						<th style="text-align:right">Cap</th>
						<th style="width:2rem"></th>
					</tr>
				</thead>
				<tbody>
					for _, rate := range rates {
						<tr>
							<td style="color:var(--muted)">
								if rate.CategoryName != "" {
									<span style="color:var(--text)">{ rate.CategoryName }</span>
								} else if rate.RawCategory != nil {
									<span style="color:var(--yellow)">{ *rate.RawCategory } (unmatched)</span>
								} else {
									<span style="font-style:italic">catch-all</span>
								}
							</td>
							<td style="text-align:right;font-weight:600">{ fmt.Sprintf("%.1f%%", rate.RewardRate) }</td>
							<td style="text-align:right;color:var(--muted)">
								if rate.CapAmount != nil {
									{ fmt.Sprintf("$%.0f%s", *rate.CapAmount, capPeriodLabel(rate.CapPeriod)) }
								} else {
									—
								}
							</td>
							<td style="text-align:right">
								<button
									type="button"
									hx-delete={ fmt.Sprintf("/api/cards/%s/rates/%s?view=settings", accountID, rate.ID) }
									hx-target={ fmt.Sprintf("#settings-rates-%s", accountID) }
									hx-swap="outerHTML"
									style="background:none;border:none;color:var(--muted);cursor:pointer;padding:0;font-size:0.9rem;line-height:1"
									title="Remove"
								>×</button>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}
		<form
			style="display:flex;gap:0.4rem;align-items:center;flex-wrap:wrap"
			hx-post={ fmt.Sprintf("/api/cards/%s/rates?view=settings", accountID) }
			hx-target={ fmt.Sprintf("#settings-rates-%s", accountID) }
			hx-swap="outerHTML"
			hx-on--htmx-after-request="this.reset()"
		>
			<select name="category_id" class="filter-select" style="font-size:0.8rem">
				<option value="">— catch-all —</option>
				for _, cat := range categories {
					<option value={ cat.ID }>{ cat.Name }</option>
				}
			</select>
			<input
				type="number"
				name="rate"
				class="filter-input"
				style="width:80px;font-size:0.8rem"
				placeholder="Rate %"
				step="0.1"
				min="0"
				max="100"
				required
			/>
			<input
				type="number"
				name="cap_amount"
				class="filter-input"
				style="width:90px;font-size:0.8rem"
				placeholder="Cap $ (opt)"
				step="100"
				min="0"
			/>
			<select name="cap_period" class="filter-select" style="font-size:0.8rem">
				<option value="">No cap</option>
				<option value="annual">Annual</option>
				<option value="monthly">Monthly</option>
			</select>
			<button type="submit" class="btn btn-ghost" style="font-size:0.8rem;padding:0.25rem 0.6rem">+ Add rate</button>
		</form>
	</div>
}

templ settingsAI(model string) {
	<div class="card">
		<h2 style="margin-bottom:0.25rem">AI & Categorization</h2>
		<p style="color:var(--muted);font-size:0.8rem;margin-bottom:1rem">OpenRouter model used for LLM categorization. Only merchant names are sent — no amounts or account info.</p>
		<form
			style="display:flex;gap:0.5rem;align-items:center"
			hx-post="/api/settings/openrouter-model"
			hx-target="#model-save-result"
			hx-swap="innerHTML"
		>
			<label style="font-size:0.85rem;color:var(--muted);white-space:nowrap">Model:</label>
			<input
				type="text"
				name="model"
				class="filter-input"
				style="width:320px;font-family:monospace"
				value={ model }
				placeholder="e.g. deepseek/deepseek-r1-0528-qwen3-8b:free"
			/>
			<button type="submit" class="btn btn-ghost" style="font-size:0.8rem;padding:0.25rem 0.6rem">Save</button>
			<span id="model-save-result" style="font-size:0.75rem"></span>
		</form>
		<p style="color:var(--muted);font-size:0.75rem;margin-top:0.75rem">
			Saved value takes precedence over the <code style="background:var(--border);padding:1px 4px;border-radius:3px">OPENROUTER_MODEL</code> env var.
			Find models at <span style="color:var(--accent)">openrouter.ai/models</span>.
		</p>
	</div>
}

templ settingsExport() {
	<div class="card">
		<h2 style="margin-bottom:0.25rem">Export Data</h2>
		<p style="color:var(--muted);font-size:0.8rem;margin-bottom:1rem">Download your transaction history. Optional date range filter.</p>
		<div style="display:flex;gap:1.5rem;flex-wrap:wrap">
			<div style="display:flex;flex-direction:column;gap:0.5rem">
				<div style="display:flex;gap:0.4rem;align-items:center;font-size:0.85rem">
					<label style="color:var(--muted);width:3rem">From</label>
					<input type="date" id="export-from" class="filter-input" style="width:160px"/>
				</div>
				<div style="display:flex;gap:0.4rem;align-items:center;font-size:0.85rem">
					<label style="color:var(--muted);width:3rem">To</label>
					<input type="date" id="export-to" class="filter-input" style="width:160px"/>
				</div>
			</div>
			<div style="display:flex;flex-direction:column;gap:0.5rem;justify-content:center">
				<a
					id="export-csv-link"
					href="/api/export?format=csv"
					class="btn btn-ghost"
					style="font-size:0.85rem;text-align:center"
					onclick="updateExportLinks(event, this)"
				>Download CSV</a>
				<a
					id="export-json-link"
					href="/api/export?format=json"
					class="btn btn-ghost"
					style="font-size:0.85rem;text-align:center"
					onclick="updateExportLinks(event, this)"
				>Download JSON</a>
			</div>
		</div>
		<script>
			function updateExportLinks(e, clicked) {
				const from = document.getElementById('export-from').value;
				const to = document.getElementById('export-to').value;
				['csv','json'].forEach(fmt => {
					const el = document.getElementById('export-' + fmt + '-link');
					let url = '/api/export?format=' + fmt;
					if (from) url += '&from=' + from;
					if (to) url += '&to=' + to;
					el.href = url;
				});
			}
		</script>
	</div>
}

func catColor(cat db.Category) string {
	if cat.Color != nil && *cat.Color != "" {
		return *cat.Color
	}
	return "#64748b"
}

type tagSpendEntry struct {
	Total    float64
	TxnCount int64
}

func tagSpendMap(rows []db.GetSpendByTagRow) map[string]tagSpendEntry {
	m := make(map[string]tagSpendEntry, len(rows))
	for _, r := range rows {
		m[r.ID] = tagSpendEntry{Total: r.Total, TxnCount: r.TxnCount}
	}
	return m
}
